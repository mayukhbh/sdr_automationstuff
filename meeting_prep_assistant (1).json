        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={ \"email\": {{ JSON.stringify($json.email) }}, \"organization_name\": {{ JSON.stringify($json.companyName) }}, \"domain\": {{ JSON.stringify($json.companyDomain) }}, \"reveal_personal_emails\": false }",
        "options": {
