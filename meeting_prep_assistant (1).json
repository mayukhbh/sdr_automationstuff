            }
          }
        }
      },
      "id": "51569207-2ffb-4316-b6cf-ea5fcfce299d",
      "name": "Enrich Company & Contact",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        440,
        300
      ],
      "credentials": {
        "httpHeaderAuth": {
          "id": "REPLACE_WITH_CREDENTIAL_ID",
          "name": "Enrichment API (Apollo / PDL / Clearbit / Crustdata)"
        }
      },
      "notes": "Single call returns the person PLUS their organization's firmographics, tech stack, and funding history. Apollo people/match shown; swap endpoint/body/credential for your provider. Verify match rate on your real (Indian D2C) target accounts first."
    },
    {
      "parameters": {
        "url": "https://newsapi.org/v2/everything",
        "authentication": "genericCredentialType",
        "genericAuthType": "httpHeaderAuth",
        "sendQuery": true,
        "queryParameters": {
          "parameters": [
            {
              "name": "q",
              "value": "={{ $('Extract Attendee Info').item.json.companyName }}"
            },
            {
              "name": "sortBy",
              "value": "publishedAt"
