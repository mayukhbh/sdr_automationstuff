              "neverError": true
            }
          }
        }
      },
      "id": "b863d635-dffb-4891-af17-c21271f19375",
      "name": "Recent News",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        660,
        300
      ],
      "credentials": {
        "httpHeaderAuth": {
          "id": "REPLACE_WITH_CREDENTIAL_ID",
          "name": "News API (NewsAPI / signal provider)"
        }
      },
      "notes": "Optional. Delete this node if your enrichment provider already returns recent news/posts."
    },
    {
      "parameters": {
        "jsCode": "const meeting = $('Extract Attendee Info').item.json;\nconst enrich  = $('Enrich Company & Contact').item.json;\nconst news    = $('Recent News').item.json;\n\nconst prompt = `You are a B2B sales research analyst. Using ONLY the data below, write a concise one-page pre-meeting brief in Slack markdown.\n\nMEETING CONTEXT:\n${JSON.stringify(meeting, null, 2)}\n\nENRICHMENT (person + company firmographics + tech stack + funding):\n${JSON.stringify(enrich, null, 2)}\n\nRECENT NEWS:\n${JSON.stringify(news, null, 2)}\n\nProduce exactly these sections with bold headers:\n*Company Overview* (3-4 sentences)\n*Likely Pains* (3-5 bullets, tied to their stage/stack/news)\n*Talking Points* (3-5 bullets)\n*Suggested Questions* (4-6 sharp discovery questions)\nKeep it under one page. If a data source is empty, omit it gracefully rather than guessing.`;\n\nreturn [{ json: { prompt } }];"
      },
      "id": "35e0acdc-2d67-4556-8134-d26a6b20576f",
      "name": "Assemble Brief Prompt",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        880,
        300
      ]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "https://api.anthropic.com/v1/messages",
        "authentication": "genericCredentialType",
        "genericAuthType": "httpHeaderAuth",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "anthropic-version",
              "value": "2023-06-01"
            },
            {
              "name": "content-type",
              "value": "application/json"
            }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={ \"model\": \"claude-3-5-sonnet-20241022\", \"max_tokens\": 1600, \"messages\": [ { \"role\": \"user\", \"content\": {{ JSON.stringify($json.prompt) }} } ] }",
        "options": {}
      },
      "id": "0ad82e45-2270-4a21-b088-f9f14bd1c82c",
      "name": "Generate Brief (Claude)",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        1100,
        300
      ],
      "credentials": {
        "httpHeaderAuth": {
          "id": "REPLACE_WITH_CREDENTIAL_ID",
          "name": "Anthropic API (x-api-key header)"
        }
      },
      "notes": "Header credential must set x-api-key = your Anthropic key."
    },
    {
      "parameters": {
        "resource": "message",
        "operation": "post",
        "select": "channel",
        "channelId": {
          "__rl": true,
          "value": "={{ $('Extract Attendee Info').item.json.ownerSlackChannel }}",
          "mode": "id"
        },
        "text": "=:calendar: *Meeting Prep Brief \u2014 {{ $('Extract Attendee Info').item.json.companyName }}*\n\n{{ $json.content[0].text }}",
        "otherOptions": {}
      },
